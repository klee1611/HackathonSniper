# Test Configuration - ZERO external dependencies needed!
# This configuration enables complete pipeline testing without API keys

# Mock API keys (these trigger mock mode)
GROQ_API_KEY=test_key
NOTION_API_KEY=test_key
NOTION_DATABASE_ID=test_db_id

# Force mock mode for environment isolation
USE_MOCK_MCP=true

# Test environment settings
NODE_ENV=test
LOG_LEVEL=info

# Test mode flag (enables single query testing)
TEST_MODE=false
TEST_QUERY=AI hackathon 2026 devpost