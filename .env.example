# ==========================================
# API Configuration
# ==========================================

# Groq API for AI evaluation
GROQ_API_KEY=your_groq_api_key_here

# Notion API for MCP integration
# NOTION_API_KEY is used by the app; NOTION_TOKEN is read by @notionhq/notion-mcp-server v2.x
NOTION_API_KEY=your_notion_api_key_here
NOTION_TOKEN=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Brave Search API for MCP integration
BRAVE_API_KEY=your_brave_api_key_here

# ==========================================
# Development Configuration
# ==========================================

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Node Environment (development, production)
# Note: test environment automatically uses mocks for isolation
NODE_ENV=development

# Test Mode (single query test vs full pipeline)
TEST_MODE=false
TEST_QUERY=AI hackathon 2026

# ==========================================
# Search Configuration
# ==========================================

# Maximum results per search query
MAX_SEARCH_RESULTS=15

# Batch size for processing
BATCH_SIZE=5

# Delay between batches (ms)
DELAY_BETWEEN_BATCHES=1000